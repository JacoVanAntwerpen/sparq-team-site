---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/Section.astro';
import { getCollection } from 'astro:content';
import { marked } from 'marked';

export async function getStaticPaths() {
  const entries = await getCollection('resources');
  return entries.map((e) => ({ params: { slug: e.slug }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const md = (s?: string) => (s ? marked.parse(s) : '');

/** Merge new `citations` array with legacy `citation` string */
const citations: string[] = [
  ...(Array.isArray(entry.data.citations) ? entry.data.citations : []),
  ...(entry.data.citation ? [entry.data.citation] : []),
];

---
<BaseLayout title={`${entry.data.title} — Resources — SPARQ Team`}>
  <Section id="resource" title={entry.data.title} subtitle={entry.data.oneLine}>
    {(() => {
      const hero = entry.data.heroImage || entry.data.image;
      return hero ? (
        <img src={hero} alt={entry.data.title} class="w-full max-w-3xl rounded-2xl shadow-sm mb-6" loading="eager" />
      ) : null;
    })()}


    {entry.data.summary && <p class="text-neutral-800">{entry.data.summary}</p>}

    {/* Long details markdown (optional) */}
    {entry.data.longDetails && (
      <div class="prose max-w-none" set:html={md(entry.data.longDetails)} />
    )}

    {/* Body content (optional; if any markdown exists below the frontmatter) */}
    <article class="prose max-w-none">
      <Content />
    </article>
    
    {entry.data.links?.length > 0 && (
      <div class="mt-6">
        <h3 class="font-semibold mb-2">Links</h3>
        <ul class="list-disc pl-5">
          {entry.data.links.map((l) => (
            <li><a class="text-blue-700 underline" href={l.url} target="_blank">{l.label}</a></li>
          ))}
        </ul>
      </div>
    )}

    {entry.data.files?.length > 0 && (
      <div class="mt-6">
        <h3 class="font-semibold mb-2">Downloads</h3>
        <ul class="list-disc pl-5">
          {entry.data.files.map((f) => (
            <li><a class="text-blue-700 underline" href={f.file} download>{f.label}</a></li>
          ))}
        </ul>
      </div>
    )}

    {entry.data.citation && (
      <div class="mt-6">
        <h3 class="font-semibold mb-2">Please site using:</h3>
        <div class="text-xs text-neutral-500">{entry.data.citation}</div>
      </div>
    )}
  </Section>
</BaseLayout>
